{
  "respectGitignore": false,
  "permissions": {
    "allow": [
      "Bash(mgrep:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:mcp-registry.com)",
      "WebFetch(domain:docs.starrocks.io)",
      "WebFetch(domain:clickhouse.com)",
      "WebFetch(domain:www.reddit.com)",
      "WebFetch(domain:scottspence.com)",
      "WebFetch(domain:blog.fsck.com)",
      "Bash(gh api:*)",
      "WebFetch(domain:api.github.com)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(ln:*)",
      "Bash(git config:*)",
      "Bash(gh repo:*)",
      "Bash(npx tsc:*)",
      "Bash(git:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/observe.sh pre"
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-mgrep-first.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-co-authored-by.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-context-freshness.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/observe.sh post"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup ~/.claude/hooks/claude-mem-export.sh </dev/null >>~/.claude-mem/export-stderr.log 2>&1 &"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '[.message, .cwd] | @tsv' | { IFS=$'\\t' read -r msg dir; osascript -e \"display notification \\\"$msg\\\" with title \\\"Claude Code\\\" subtitle \\\"$dir\\\" sound name \\\"Glass\\\"\"; printf '\\a' > /dev/tty; }"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": false,
    "mgrep@Mixedbread-Grep": true,
    "superpowers@superpowers-marketplace": true,
    "claude-md-management@claude-plugins-official": true,
    "superpowers-developing-for-claude-code@superpowers-marketplace": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "skill-creator@claude-plugins-official": true,
    "claude-session-driver@superpowers-marketplace": true
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "Mixedbread-Grep": {
      "source": {
        "source": "github",
        "repo": "mixedbread-ai/mgrep"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "mcpServers": {
    "playwright-extension": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--extension"
      ]
    }
  },
  "teammateMode": "in-process",
  "compactInstructions": "Preserve: current goal, files changed with reasons, decisions made (and rejected alternatives), remaining steps, error resolutions. Discard: full file contents, search/grep output, tool results, exploratory reasoning.",
  "skipDangerousModePermissionPrompt": true
}
